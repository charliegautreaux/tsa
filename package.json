{
  "name": "preboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && node scripts/inject-cron.mjs && wrangler dev",
    "deploy": "opennextjs-cloudflare build && node scripts/inject-cron.mjs && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply preboard-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply preboard-db --remote",
    "db:seed:local": "npx tsx scripts/seed-airports.ts --local",
    "db:seed:remote": "npx tsx scripts/seed-airports.ts --remote",
    "db:seed:dev": "npx tsx scripts/seed-dev-data.ts",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@opennextjs/cloudflare": "^1.18.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1",
    "wrangler": "^4.77.0"
  }
}
